# ─────────────────────────────────────────────────────────────────
# GastroAdmin — variables de entorno
# Copiar este archivo como .env.local y rellenar con tus claves.
# Nunca commitear .env.local.
# ─────────────────────────────────────────────────────────────────

# Supabase (crear proyecto en https://supabase.com/dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key

# Token fijo para proteger la vista /cocina.
# Generar uno random: openssl rand -base64 24
COCINA_TOKEN=cambiar-por-un-string-random-largo

# Service role key SOLO si necesitás operaciones admin del lado servidor.
# NUNCA exponer al cliente. NUNCA commitear.
# SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key
