# Supabase (crear proyecto en https://supabase.com/dashboard)
# Copiar este archivo como .env.local y rellenar con tus claves propias
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key-publica

# Service role key SOLO si necesitas operaciones admin del lado servidor.
# NUNCA exponer al cliente. NUNCA commitear.
# SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# Token fijo para proteger la vista /cocina (elegí un string random largo).
# Ej: generar con: openssl rand -hex 16
COCINA_TOKEN=cambiame-por-un-string-largo-y-random
